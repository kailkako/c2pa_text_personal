[package]
name = "c2pa-text"
version = "2.0.0"
edition = "2021"
description = "Reference implementation for embedding C2PA manifests in text using Unicode variation selectors"
authors = ["Encypher Corporation <contact@encypher.com>"]
license = "MIT"
readme = "README.md"
repository = "https://github.com/encypherai/c2pa-text"
keywords = ["c2pa", "text", "steganography", "unicode", "provenance"]
categories = ["text-processing", "encoding"]

[dependencies]
base64 = "0.22"
unicode-normalization = "0.1"

[dev-dependencies]
serde_json = "1"
